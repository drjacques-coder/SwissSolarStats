solar_plants_2024 <- all_plants_raw %>%
filter(SubCategory == "subcat_2") %>%
mutate(operation_date = ymd(BeginningOfOperation)) %>%
filter(operation_date <= "2024-12-31") %>%
select(
Canton,
Municipality,
PostCode,
operation_date,
InitialPower,
TotalPower
